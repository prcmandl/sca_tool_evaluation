    "coordinates": "pkg:nuget/Refit@6.0.15",
    "reference": "https://ossindex.sonatype.org/component/pkg:nuget/Refit@6.0.15?utm_source=evaltech-report&utm_medium=integration&utm_content=ossindex-adapter",
