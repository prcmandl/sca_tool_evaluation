  {
    "coordinates": "pkg:npm/tar@7.5.3",
    "description": "tar for node",
    "reference": "https://ossindex.sonatype.org/component/pkg:npm/tar@7.5.3?utm_source=evaltech-report&utm_medium=integration&utm_content=ossindex-adapter",
