        "reference": "https://ossindex.sonatype.org/vulnerability/CVE-2025-66471?component-type=pypi&component-name=urllib3&utm_source=evaltech-report&utm_medium=integration&utm_content=ossindex-adapter",
        "externalReferences": [
          "http://web.nvd.nist.gov/view/vuln/detail?vulnId=CVE-2025-66471",
