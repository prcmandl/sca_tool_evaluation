      "uuid": "e5d96a87-2e54-49cf-9c34-aeaf781d8cec",
      "name": "org.apache.commons:commons-compress",
      "version": "1.22",
      "purl": "pkg:maven/org.apache.commons/commons-compress@1.22",
      "project": "69720014-b766-4d4e-ba56-e44fc925face",
