      "uuid": "7a37284f-b22d-4885-bb1b-f37ae978ddd3",
      "name": "RestSharp",
      "version": "108.0.2",
      "purl": "pkg:nuget/RestSharp@108.0.2",
      "project": "69720014-b766-4d4e-ba56-e44fc925face",
