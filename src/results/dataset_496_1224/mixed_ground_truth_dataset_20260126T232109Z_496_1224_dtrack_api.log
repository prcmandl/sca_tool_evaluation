  {
    "component": {
      "uuid": "9169d296-df2c-4c58-8aa0-feab31c8f50a",
      "name": "urllib3",
      "version": "2.6.1",
      "purl": "pkg:pypi/urllib3@2.6.1",
      "project": "69720014-b766-4d4e-ba56-e44fc925face",
      "latestVersion": "2.6.3"
