  {
    "component": {
      "uuid": "8686f673-cb09-4dd6-93ba-2813d292dd34",
      "name": "urllib3",
      "version": "2.2.3",
      "purl": "pkg:pypi/urllib3@2.2.3",
      "project": "69720014-b766-4d4e-ba56-e44fc925face",
