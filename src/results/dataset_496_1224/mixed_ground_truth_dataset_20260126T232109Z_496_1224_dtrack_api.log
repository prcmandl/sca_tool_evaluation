  {
    "component": {
      "uuid": "e29cdf57-e323-4818-9a48-d3786953b09a",
      "name": "passport",
      "version": "0.5.3",
      "purl": "pkg:npm/passport@0.5.3",
      "project": "69720014-b766-4d4e-ba56-e44fc925face",
